---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact NGSAC" description="Contact information for NGSAC.">
  <section class="page-head">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Contact NGSAC</h1>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-panel card">
        <p>
          If you are interested in working with NGSAC, please contact the chairs at
          <strong> ngsac.chair (at) gmail.com</strong> or any committee member.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
